# ─────────────────────────────────────────────
# Weather (Meteosource)
# ─────────────────────────────────────────────
# Sign up for a free API key at https://www.meteosource.com
METEOSOURCE_API_KEY=your_key_here

# Coordinates of your location (decimal degrees)
WEATHER_LAT=40.7527
WEATHER_LON=-73.9772

# IANA timezone name — use "America/New_York" for NYC
WEATHER_TIMEZONE=America/New_York

# Language for weather condition text (e.g. en, es, fr)
WEATHER_LANGUAGE=en

# Unit system: "us" for °F/mph, "metric" for °C/km/h
WEATHER_UNITS=us


# ─────────────────────────────────────────────
# MTA Transit Feed
# ─────────────────────────────────────────────
# No API key required.
#
# Pick the feed URL for your subway lines from the list below.
# Use multiple URLs separated by commas if your station serves
# lines from different feeds.
#
# Feed URLs:
#   1 2 3 4 5 6 7  → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs
#   A C E          → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-ace
#   B D F M        → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-bdfm
#   G              → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-g
#   J Z            → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-jz
#   L              → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-l
#   N Q R W        → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-nqrw
#   SIR            → https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-si
MTA_FEED_URLS=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs


# ─────────────────────────────────────────────
# Subway Stops
# ─────────────────────────────────────────────
# Format:  stop_id:northbound_label:southbound_label[:lines]
# Separate multiple stops with |
#
# "lines" is optional — a comma-separated list of route letters/numbers
# to show at that stop. Omit it to show all lines that serve the stop.
#
# Finding your stop ID:
#   1. Download the MTA GTFS static package:
#      https://api.mta.info/GTFS.zip
#   2. Open stops.txt in a spreadsheet or text editor.
#   3. Search for your station name — each platform has its own stop_id.
#      The same station may have multiple IDs (one per line/platform).
#   4. The real-time feed appends N or S to the stop_id for direction
#      (e.g. 631N = northbound at stop 631). You only enter the base ID here.
#
# Common examples:
#   Grand Central - 42 St (4/5/6 platform) → 631
#   Grand Central - 42 St (7 platform)      → 726
#   Times Sq - 42 St (1/2/3 platform)       → 127
#   Times Sq - 42 St (N/Q/R/W platform)     → R16
#   Atlantic Av - Barclays Ctr (2/3/4/5)    → 235
#   Jay St - MetroTech (A/C/F)              → A41
#
# Example — Grand Central, showing 4+5 on one platform and 7 on the other:
SUBWAY_STOPS=631:Uptown:Downtown:4,5|726:Flushing:Hudson Yards:7
